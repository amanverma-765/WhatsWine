{
  "name": "whatswine",
  "productName": "WhatsWine",
  "version": "1.0.0",
  "description": "Unofficial WhatsApp desktop client for Linux — an Electron shell over WhatsApp Web's Windows-hybrid bundle.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:linux": "rm -rf out && electron-forge make --platform=linux --arch=x64",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "postinstall": "node packaging/rpm/patch-spec.mjs",
    "make:linux:portable": "docker build -t whatswine-builder packaging/builder && docker run --rm -v \"$PWD:/src\" whatswine-builder bash /src/packaging/builder/build.sh",
    "release": "gh workflow run release && sleep 5 && gh run watch $(gh run list --workflow=release --limit 1 --json databaseId --jq '.[0].databaseId')"
  },
  "keywords": [],
  "author": {
    "name": "amanverma-765",
    "email": "akverma4aman@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@reforged/maker-appimage": "^5.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "42.4.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~5.4.5",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@signalapp/libsignal-client": "^0.96.2",
    "better-sqlite3": "^12.11.1",
    "electron-squirrel-startup": "^1.0.1",
    "undici": "^7.28.0"
  }
}
