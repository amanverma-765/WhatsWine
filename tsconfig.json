{
  "compilerOptions": {
    "target": "ESNext",
    // ESM module syntax: the source uses import.meta.glob (Vite resolves it at build).
    // tsc is type-check-only here (--noEmit); Vite/esbuild emit the actual main/preload.
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "resolveJsonModule": true
  }
}
