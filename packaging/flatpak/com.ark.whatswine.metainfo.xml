<component type="desktop-application">
  <id>com.ark.whatswine</id>
  <name>WhatsWine</name>
  <summary>Unofficial WhatsApp desktop client</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>
      WhatsWine is an unofficial WhatsApp desktop client for Linux. It ports the
      native WhatsApp-for-Windows hybrid architecture to Electron: the real
      WhatsApp Web bundle runs against native bridges for SQLite persistence,
      notifications, and system integration, with real 1:1 voice and video
      calling, screen sharing, and tray support.
    </p>
    <p>
      This project is not affiliated with, endorsed by, or supported by WhatsApp
      LLC or Meta Platforms, Inc.
    </p>
  </description>
